<Window x:Class="AppExam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход" Height="420" Width="520"
        MinHeight="380" MinWidth="460"
        FontFamily="Comic Sans MS"
        Background="White">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="95"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Background" Value="#ABCFCE"/>
            <Setter Property="BorderBrush" Value="#546F94"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="5,1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Border Width="360" Padding="22" BorderBrush="#546F94" BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Книжный магазин" FontSize="20" FontWeight="Bold"
                           TextAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="Логин"/>
                <TextBox x:Name="LoginTextBox" Text="94d5ous@gmail.com"/>
                <TextBlock Text="Пароль" Margin="0,8,0,0"/>
                <PasswordBox x:Name="PasswordBox" Height="26" Margin="4" Padding="5,2" Password="uzWC67"/>
                <Button x:Name="LoginButton" Content="Войти" Background="#546F94" Foreground="White" Click="LoginButton_Click"/>
                <Button x:Name="GuestButton" Content="Гость" Click="GuestButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
