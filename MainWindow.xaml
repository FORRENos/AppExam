<Window x:Class="AppExam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Книжный магазин" Height="760" Width="1180"
        MinHeight="680" MinWidth="980"
        FontFamily="Comic Sans MS"
        Background="#FFFFFF">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Background" Value="#ABCFCE"/>
            <Setter Property="BorderBrush" Value="#546F94"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="LoginPanel" Background="#FFFFFF">
            <Border Width="430" Padding="28" BorderBrush="#546F94" BorderThickness="2"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Книжный магазин" FontSize="26" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <TextBlock Text="Логин"/>
                    <TextBox x:Name="LoginTextBox" Text="94d5ous@gmail.com"/>
                    <TextBlock Text="Пароль" Margin="0,8,0,0"/>
                    <PasswordBox x:Name="PasswordBox" MinHeight="32" Margin="4" Padding="8,3" Password="uzWC67"/>
                    <Button Content="Войти" Background="#546F94" Foreground="White" Click="LoginButton_Click"/>
                    <Button Content="Продолжить как гость" Click="GuestButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="MainPanel" Visibility="Collapsed" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <TextBlock x:Name="CurrentUserTextBlock" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Content="Выйти" Click="LogoutButton_Click"/>
                </StackPanel>
                <TextBlock Text="Список товаров" FontSize="26" FontWeight="Bold"/>
            </DockPanel>

            <Border Grid.Row="1" Background="#ABCFCE" Padding="8" Margin="0,14,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchTextBox" Grid.Column="0" TextChanged="FilterControl_Changed"
                             ToolTip="Поиск по названию, описанию, производителю и поставщику"/>
                    <ComboBox x:Name="SortComboBox" Grid.Column="1" SelectionChanged="FilterControl_Changed">
                        <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                        <ComboBoxItem Content="Цена по возрастанию"/>
                        <ComboBoxItem Content="Цена по убыванию"/>
                        <ComboBoxItem Content="Остаток по возрастанию"/>
                        <ComboBoxItem Content="Остаток по убыванию"/>
                    </ComboBox>
                    <ComboBox x:Name="DiscountComboBox" Grid.Column="2" SelectionChanged="FilterControl_Changed">
                        <ComboBoxItem Content="Все диапазоны" IsSelected="True"/>
                        <ComboBoxItem Content="0-12,99%"/>
                        <ComboBoxItem Content="13-16,99%"/>
                        <ComboBoxItem Content="17% и более"/>
                    </ComboBox>
                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <Button x:Name="AddProductButton" Content="Добавить товар" Click="AddProductButton_Click"/>
                        <Button x:Name="EditProductButton" Content="Редактировать" Click="EditProductButton_Click"/>
                        <Button x:Name="DeleteProductButton" Content="Удалить" Click="DeleteProductButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ListView x:Name="ProductsListView" Grid.Row="2">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="{Binding RowBrush}"/>
                        <Setter Property="Margin" Value="0,0,0,6"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#546F94" BorderThickness="1" Padding="10" Background="{Binding RowBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="#546F94" BorderThickness="1" Height="90" Margin="0,0,12,0">
                                    <TextBlock Text="Фото" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontSize="17" FontWeight="Bold">
                                        <Run Text="{Binding CategoryName}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding Name}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                    <TextBlock><Run Text="Производитель: "/><Run Text="{Binding ManufacturerName}"/></TextBlock>
                                    <TextBlock><Run Text="Поставщик: "/><Run Text="{Binding SupplierName}"/></TextBlock>
                                    <TextBlock><Run Text="Цена: "/><Run Text="{Binding PriceText}"/></TextBlock>
                                    <TextBlock><Run Text="Единица измерения: "/><Run Text="{Binding UnitName}"/></TextBlock>
                                    <TextBlock><Run Text="Количество на складе: "/><Run Text="{Binding QuantityInStock}"/></TextBlock>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding Discount, StringFormat=Действующая скидка: {0}%}"
                                           TextWrapping="Wrap" FontWeight="Bold" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" TextAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Window>
