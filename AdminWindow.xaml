<Window x:Class="AppExam.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Каталог" Height="620" Width="980"
        MinHeight="560" MinWidth="900"
        FontFamily="Comic Sans MS"
        Background="White">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="95"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Background" Value="#ABCFCE"/>
            <Setter Property="BorderBrush" Value="#546F94"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="5,1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="WindowName" Text="КАТАЛОГ" FontSize="18" FontWeight="Bold"
                           TextAlignment="Center" HorizontalAlignment="Center" Width="260"/>
                <TextBlock x:Name="UserNameTextBlock" Text="Гость" FontSize="14"
                           TextAlignment="Center" HorizontalAlignment="Center" Width="360"/>
            </StackPanel>
            <Button x:Name="LogoutButton" Grid.Column="1" Content="Выйти" Click="LogoutButton_Click"/>
        </Grid>

        <DataGrid x:Name="ProductsDataGrid" Grid.Row="1" Margin="0,8,0,8"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{Binding RowBrush}"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Артикул" Binding="{Binding Article}" Width="80"/>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="160"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="130"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="220"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding ManufacturerName}" Width="130"/>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding SupplierName}" Width="130"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding PriceText}" Width="110"/>
                <DataGridTextColumn Header="Ед. изм." Binding="{Binding UnitName}" Width="70"/>
                <DataGridTextColumn Header="Остаток" Binding="{Binding QuantityInStock}" Width="70"/>
                <DataGridTextColumn Header="Скидка" Binding="{Binding Discount}" Width="70"/>
                <DataGridTextColumn Header="Фото" Binding="{Binding PhotoPath}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Поиск" VerticalAlignment="Center" Margin="4"/>
            <TextBox x:Name="SearchTextBox" Grid.Row="0" Grid.Column="1" TextChanged="FilterControl_Changed"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="Сортировка" VerticalAlignment="Center" Margin="12,4,4,4"/>
            <ComboBox x:Name="SortComboBox" Grid.Row="0" Grid.Column="3" SelectionChanged="FilterControl_Changed">
                <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                <ComboBoxItem Content="Цена ↑"/>
                <ComboBoxItem Content="Цена ↓"/>
                <ComboBoxItem Content="Остаток ↑"/>
                <ComboBoxItem Content="Остаток ↓"/>
            </ComboBox>

            <TextBlock Grid.Row="0" Grid.Column="4" Text="Скидка" VerticalAlignment="Center" Margin="12,4,4,4"/>
            <ComboBox x:Name="DiscountComboBox" Grid.Row="0" Grid.Column="5" SelectionChanged="FilterControl_Changed">
                <ComboBoxItem Content="Все диапазоны" IsSelected="True"/>
                <ComboBoxItem Content="0-12,99%"/>
                <ComboBoxItem Content="13-16,99%"/>
                <ComboBoxItem Content="17% и более"/>
            </ComboBox>

            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="7" Orientation="Horizontal" Margin="0,6,0,0">
                <Button x:Name="AddProductButton" Content="Добавить" Click="AddProductButton_Click"/>
                <Button x:Name="EditProductButton" Content="Изменить" Click="EditProductButton_Click"/>
                <Button x:Name="DeleteProductButton" Content="Удалить" Click="DeleteProductButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
